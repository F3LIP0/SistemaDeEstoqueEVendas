{
  "name": "fluxa-web",
  "version": "2.0.0",
  "description": "fluxa web: gerenciamento de estoque, vendas e controle operacional com PostgreSQL",
  "main": "backend.js",
  "scripts": {
    "start": "node backend.js",
    "start:backend": "node backend.js",
    "start:frontend": "node frontend-server.js",
    "start:all": "sh -c 'node backend.js & node frontend-server.js'",
    "dev": "nodemon backend.js",
    "test": "node test-complete-endpoints.js",
    "test:fluxo": "node test-fluxo-completo.js",
    "test:sistema": "node test-sistema-completo.js",
    "test:all": "node scripts/test-all.js",
    "test:all:raw": "npm run test && npm run test:fluxo && npm run test:sistema",
    "health": "node -e \"fetch('http://localhost:3000/api/health').then(async r=>{console.log(r.status, await r.text()); process.exit(r.ok?0:1);}).catch(e=>{console.error(e.message); process.exit(1);});\"",
    "create-admin": "node create-admin.js"
  },
  "keywords": [
    "estoque",
    "vendas",
    "ponto",
    "gestão",
    "sistema",
    "postgresql",
    "inventory",
    "sales"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
